# ===========================================================================
#  .gitignore  (WindowsAudioControl-CLI-wGUI)
# ---------------------------------------------------------------------------

# --- built executables (any location: dist, Scripts, deployed copies) -----
*.exe

# --- PyInstaller build byproducts ------------------------------------------
# the whole output tree is regenerated by each build and should not be committed.
build/

# --- local virtual environments (created by each BUILD_EXE.bat) ------------
.venv/
venv/

# --- Logs File (created by running the audioctl.exe GUI) ------------
*.log


# --- Python caches ---------------------------------------------------------
__pycache__/
*.pyc

